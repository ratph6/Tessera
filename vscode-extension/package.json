{
  "name": "tessera-intellisense",
  "displayName": "Tessera — JavaScript In Minecraft",
  "description": "IntelliSense and autocompletion for Tessera scripts: the ratph6.tessera.api functions and the full Mojang-mapped Minecraft API (net.minecraft.*).",
  "version": "1.3.1",
  "publisher": "ratph6",
  "engines": { "vscode": "^1.85.0" },
  "categories": ["Programming Languages", "Snippets"],
  "keywords": ["minecraft", "fabric", "tessera", "typescript", "modding"],
  "activationEvents": [
    "onStartupFinished",
    "workspaceContains:**/tessera.json"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "tessera.setupIntelliSense",
        "title": "Tessera: Set up IntelliSense in this folder"
      }
    ],
    "snippets": [
      {
        "language": "typescript",
        "path": "./snippets/mixin.code-snippets"
      },
      {
        "language": "javascript",
        "path": "./snippets/mixin.code-snippets"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "vscode:prepublish": "npm run compile",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.4.0",
    "@vscode/vsce": "^2.24.0"
  }
}
